<div>
<label>Titel</label>
<input type="text" name="name" value="<%= book.name %>">
</div>
<div>
<label>Author</label>
<select name="author">
    <% authors.forEach(author => { %>
        <option value="<%= author.id %>" <%= book.author && book.author.equals(author._id) ? 'selected' : '' %>>
            <%= author.name %>
        </option>
    <% }); %>
</select>
</div>
<div>
    <label>Publish Date</label>
    <input type="date" name="publishDate" value="<%= book.publishDate ? book.publishDate.toISOString().split('T')[0] : '' %>">
</div>
<div>
    <label>Page Count</label>
    <input type="number" name="pageCount" value="<%= book.pageCount %>">
</div>
